{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "starter-tauri-app",
  "version": "0.1.0",
  "identifier": "com.osp.starter-tauri-app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "starter-tauri-app",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJFNzAyMzQ2NjM5NzRCRTQKUldUa1M1ZGpSaU53TGlPQ29JSnFUNkR1TERWUlUxWGZHdEdUTlhqQjUzMWYwYkRHUzd5TW5jcGIK",
      "endpoints": [
        "https://github.com/OSpoon/starter-tauri-app/releases/latest/download/latest.json"
      ]
    }
  }
}
